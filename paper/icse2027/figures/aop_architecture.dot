digraph AOP {
rankdir=TB;
node [shape=box, style=rounded];

Agents [label="AI Agents\nTool Invocations"];

Protocol [label="Agent Object Protocol\n(Protocol-by-Artifacts)"];

Schemas [label="Schemas"];
