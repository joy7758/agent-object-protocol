{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AOP Optional Profile: in-toto Statement v1",
  "type": "object",
  "required": ["_type", "subject", "predicateType", "predicate"],
  "properties": {
    "_type": {
      "type": "string",
      "const": "https://in-toto.io/Statement/v1"
    },
    "subject": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          },
          "digest": {
            "type": "object",
            "properties": {
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "sha512": {
                "type": "string",
                "pattern": "^[a-f0-9]{128}$"
              }
            },
            "minProperties": 1,
            "patternProperties": {
              "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
            },
            "unevaluatedProperties": false
          }
        },
        "patternProperties": {
          "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
        },
        "unevaluatedProperties": false
      }
    },
    "predicateType": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "predicate": {
      "type": "object"
    }
  },
  "patternProperties": {
    "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
  },
  "unevaluatedProperties": false
}
