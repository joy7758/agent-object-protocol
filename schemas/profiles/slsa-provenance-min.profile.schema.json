{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AOP Evidence Profile: slsa.provenance/v1 (minimal subset)",
  "allOf": [
    {
      "$ref": "https://github.com/joy7758/agent-object-protocol/schemas/aop-evidence.schema.json"
    },
    {
      "type": "object",
      "required": ["predicateType", "predicate"],
      "properties": {
        "predicateType": {
          "const": "https://slsa.dev/provenance/v1"
        },
        "predicate": {
          "type": "object",
          "required": ["buildDefinition", "runDetails"],
          "properties": {
            "buildDefinition": {
              "type": "object",
              "required": ["buildType"],
              "properties": {
                "buildType": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256
                },
                "externalParameters": {
                  "type": "object"
                },
                "internalParameters": {
                  "type": "object"
                },
                "resolvedDependencies": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["uri"],
                    "properties": {
                      "uri": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 1024
                      },
                      "digest": {
                        "type": "object",
                        "properties": {
                          "sha256": {
                            "type": "string",
                            "pattern": "^[a-f0-9]{64}$"
                          }
                        },
                        "minProperties": 1,
                        "patternProperties": {
                          "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
                        },
                        "unevaluatedProperties": false
                      }
                    },
                    "patternProperties": {
                      "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
                    },
                    "unevaluatedProperties": false
                  }
                }
              },
              "patternProperties": {
                "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
              },
              "unevaluatedProperties": false
            },
            "runDetails": {
              "type": "object",
              "required": ["builder"],
              "properties": {
                "builder": {
                  "type": "object",
                  "required": ["id"],
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 512
                    }
                  },
                  "patternProperties": {
                    "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
                  },
                  "unevaluatedProperties": false
                },
                "metadata": {
                  "type": "object"
                }
              },
              "patternProperties": {
                "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
              },
              "unevaluatedProperties": false
            }
          },
          "patternProperties": {
            "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
          },
          "unevaluatedProperties": false
        }
      }
    }
  ]
}
