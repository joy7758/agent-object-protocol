{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/joy7758/agent-object-protocol/schemas/aop-policy.schema.json",
  "title": "AOP Policy Object",
  "type": "object",
  "properties": {
    "aop_version": {
      "type": "string",
      "pattern": "^0\\.(?:[1-9]\\d*)$"
    },
    "id": {
      "type": "string",
      "pattern": "^urn:aop:policy:[a-z0-9][a-z0-9-]{0,63}:v[0-9]+$"
    },
    "kind": {
      "type": "string",
      "const": "policy"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "target": {
      "$ref": "#/$defs/Target"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Rule"
      }
    },
    "evaluation": {
      "$ref": "#/$defs/EvaluationContract"
    },
    "provenance": {
      "type": "object"
    }
  },
  "required": [
    "aop_version",
    "id",
    "kind",
    "name",
    "description",
    "target",
    "rules"
  ],
  "patternProperties": {
    "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
  },
  "unevaluatedProperties": false,
  "$defs": {
    "Target": {
      "type": "object",
      "properties": {
        "selector": {
          "type": "string",
          "enum": ["object_id", "object_kind", "all"]
        },
        "object_id": {
          "type": "string"
        },
        "object_kind": {
          "type": "string",
          "enum": ["tool", "workflow", "dataset", "policy"]
        }
      },
      "required": ["selector"],
      "allOf": [
        {
          "if": {
            "properties": {
              "selector": {
                "const": "object_id"
              }
            },
            "required": ["selector"]
          },
          "then": {
            "required": ["object_id"]
          }
        },
        {
          "if": {
            "properties": {
              "selector": {
                "const": "object_kind"
              }
            },
            "required": ["selector"]
          },
          "then": {
            "required": ["object_kind"]
          }
        }
      ],
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false
    },
    "Rule": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
        },
        "effect": {
          "type": "string",
          "enum": ["allow", "deny"]
        },
        "when": {
          "$ref": "#/$defs/ConditionSet"
        },
        "reason": {
          "$ref": "#/$defs/Reason"
        },
        "patch": {
          "$ref": "#/$defs/Patch"
        }
      },
      "required": ["id", "effect", "when"],
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false
    },
    "ConditionSet": {
      "type": "object",
      "description": "All conditions are ANDed and evaluated against the candidate object manifest.",
      "properties": {
        "all": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/Condition"
          }
        }
      },
      "required": ["all"],
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false
    },
    "Condition": {
      "type": "object",
      "properties": {
        "field": {
          "type": "string",
          "description": "Dotted path into a candidate object manifest (for example, security.auth.scheme)."
        },
        "op": {
          "type": "string",
          "enum": ["eq", "ne", "in", "not_in", "exists", "not_exists", "lte", "gte"]
        },
        "value": {}
      },
      "required": ["field", "op"],
      "allOf": [
        {
          "if": {
            "properties": {
              "op": {
                "enum": ["eq", "ne", "in", "not_in", "lte", "gte"]
              }
            },
            "required": ["op"]
          },
          "then": {
            "required": ["value"]
          }
        }
      ],
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false
    },
    "Reason": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z0-9_]{3,64}$"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        }
      },
      "required": ["code", "message"],
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false
    },
    "Patch": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["suggest", "require"]
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/PatchOp"
          }
        }
      },
      "required": ["type", "operations"],
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false
    },
    "PatchOp": {
      "type": "object",
      "properties": {
        "op": {
          "type": "string",
          "enum": ["add", "replace", "remove"]
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "value": {}
      },
      "required": ["op", "path"],
      "allOf": [
        {
          "if": {
            "properties": {
              "op": {
                "enum": ["add", "replace"]
              }
            },
            "required": ["op"]
          },
          "then": {
            "required": ["value"]
          }
        }
      ],
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false
    },
    "EvaluationContract": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["advisory", "enforced"]
        },
        "default_effect": {
          "type": "string",
          "enum": ["deny", "allow"]
        }
      },
      "required": ["mode", "default_effect"],
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false
    }
  }
}
