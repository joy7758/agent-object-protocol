{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/joy7758/agent-object-protocol/schemas/aop-object.schema.json",
  "title": "AOP Object Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["aop_version", "id", "kind", "name", "description", "schema"],
  "$defs": {
    "TimeoutsMs": {
      "type": "object",
      "description": "Timeout hints in milliseconds.",
      "additionalProperties": true,
      "properties": {
        "connect": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600000
        },
        "read": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600000
        },
        "overall": {
          "type": "integer",
          "minimum": 1,
          "maximum": 600000
        }
      }
    },
    "RetryPolicy": {
      "type": "object",
      "description": "Retry hints for invocation failures.",
      "additionalProperties": true,
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "backoff": {
          "type": "string",
          "enum": ["none", "fixed", "exponential"]
        },
        "retry_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "Invocation": {
      "type": "object",
      "description": "Optional invocation contract.",
      "additionalProperties": true,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["sync", "async", "stream"]
        },
        "idempotency": {
          "type": "string",
          "enum": ["idempotent", "non-idempotent", "best-effort"]
        },
        "timeouts_ms": {
          "$ref": "#/$defs/TimeoutsMs"
        },
        "retry": {
          "$ref": "#/$defs/RetryPolicy"
        }
      }
    },
    "TokenCostHint": {
      "type": "object",
      "description": "Advisory token cost hints.",
      "additionalProperties": true,
      "properties": {
        "input_per_1k": {
          "type": "integer",
          "minimum": 0
        },
        "output_per_1k": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "Capabilities": {
      "type": "object",
      "description": "Optional capability declarations.",
      "additionalProperties": true,
      "properties": {
        "side_effects": {
          "type": "string",
          "enum": ["none", "low", "high"]
        },
        "determinism": {
          "type": "string",
          "enum": ["deterministic", "bounded-nondeterministic", "nondeterministic"]
        },
        "token_cost_hint": {
          "$ref": "#/$defs/TokenCostHint"
        }
      }
    },
    "AuthConfig": {
      "type": "object",
      "description": "Authentication requirements.",
      "additionalProperties": true,
      "properties": {
        "scheme": {
          "type": "string",
          "enum": ["none", "api_key", "oauth2", "mtls", "custom"]
        },
        "scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "issuer": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "PermissionConfig": {
      "type": "object",
      "description": "Permission and access boundaries.",
      "additionalProperties": true,
      "properties": {
        "data_access": {
          "type": "string",
          "enum": ["none", "read", "write", "read-write"]
        },
        "network_access": {
          "type": "string",
          "enum": ["none", "restricted", "unrestricted"]
        },
        "required_resources": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "IntegrityConfig": {
      "type": "object",
      "description": "Integrity and signing metadata.",
      "additionalProperties": true,
      "properties": {
        "checksum_algo": {
          "type": "string",
          "enum": ["sha256", "sha512"]
        },
        "checksum": {
          "type": "string",
          "pattern": "^(?:[A-Fa-f0-9]{64}|[A-Fa-f0-9]{128})$"
        },
        "signed": {
          "type": "boolean"
        },
        "signature_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Security": {
      "type": "object",
      "description": "Optional security/provenance/integrity declarations.",
      "additionalProperties": true,
      "properties": {
        "auth": {
          "$ref": "#/$defs/AuthConfig"
        },
        "permissions": {
          "$ref": "#/$defs/PermissionConfig"
        },
        "integrity": {
          "$ref": "#/$defs/IntegrityConfig"
        }
      }
    }
  },
  "properties": {
    "aop_version": {
      "type": "string",
      "description": "AOP spec version that this object targets (not the repo tag).",
      "pattern": "^0\\.(?:[1-9]\\d*)$"
    },
    "id": {
      "type": "string",
      "description": "AOP object identifier URN.",
      "pattern": "^urn:aop:(tool|workflow|dataset|policy):[a-z0-9][a-z0-9-]{0,63}:v[0-9]+$"
    },
    "kind": {
      "type": "string",
      "enum": ["tool", "workflow", "dataset", "policy"]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputs", "outputs"],
      "properties": {
        "inputs": {
          "description": "JSON Schema describing invocation inputs.",
          "$ref": "https://json-schema.org/draft/2020-12/schema"
        },
        "outputs": {
          "description": "JSON Schema describing invocation outputs.",
          "$ref": "https://json-schema.org/draft/2020-12/schema"
        }
      }
    },
    "invocation": {
      "$ref": "#/$defs/Invocation"
    },
    "capabilities": {
      "$ref": "#/$defs/Capabilities"
    },
    "security": {
      "$ref": "#/$defs/Security"
    },
    "provenance": {
      "type": "object",
      "description": "Optional publisher/source metadata.",
      "additionalProperties": true
    }
  }
}
