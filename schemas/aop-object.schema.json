{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/joy7758/agent-object-protocol/schemas/aop-object.schema.json",
  "title": "AOP Object Manifest",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
  },
  "unevaluatedProperties": false,
  "required": ["aop_version", "id", "kind", "name", "description", "schema"],
  "$defs": {
    "TimeoutsMs": {
      "type": "object",
      "description": "Timeout hints in milliseconds.",
      "$comment": "Hints only; runtimes may enforce stricter internal caps.",
      "additionalProperties": true,
      "properties": {
        "connect": {
          "description": "Connection establishment timeout in milliseconds.",
          "examples": [3000],
          "type": "integer",
          "minimum": 1,
          "maximum": 600000
        },
        "read": {
          "description": "Read timeout in milliseconds after connection.",
          "examples": [15000],
          "type": "integer",
          "minimum": 1,
          "maximum": 600000
        },
        "overall": {
          "description": "Overall invocation timeout budget in milliseconds.",
          "examples": [30000],
          "type": "integer",
          "minimum": 1,
          "maximum": 600000
        }
      }
    },
    "RetryPolicy": {
      "type": "object",
      "description": "Retry hints for invocation failures.",
      "additionalProperties": true,
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "backoff": {
          "type": "string",
          "enum": ["none", "fixed", "exponential"]
        },
        "retry_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "Invocation": {
      "type": "object",
      "description": "Optional invocation contract.",
      "additionalProperties": false,
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false,
      "required": ["mode", "idempotency"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["sync", "async", "stream"]
        },
        "idempotency": {
          "type": "string",
          "enum": ["idempotent", "non-idempotent", "best-effort"]
        },
        "timeouts_ms": {
          "$ref": "#/$defs/TimeoutsMs"
        },
        "retry": {
          "$ref": "#/$defs/RetryPolicy"
        }
      }
    },
    "TokenCostHint": {
      "type": "object",
      "description": "Advisory token cost hints.",
      "$comment": "Annotation only; values guide scheduling/cost-aware planning.",
      "additionalProperties": true,
      "properties": {
        "input_per_1k": {
          "description": "Estimated input-token cost units per 1K tokens.",
          "examples": [1200],
          "type": "integer",
          "minimum": 0
        },
        "output_per_1k": {
          "description": "Estimated output-token cost units per 1K tokens.",
          "examples": [800],
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "Capabilities": {
      "type": "object",
      "description": "Optional capability declarations.",
      "additionalProperties": false,
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false,
      "required": ["side_effects", "determinism"],
      "properties": {
        "side_effects": {
          "type": "string",
          "enum": ["none", "low", "high"]
        },
        "determinism": {
          "type": "string",
          "enum": ["deterministic", "bounded-nondeterministic", "nondeterministic"]
        },
        "token_cost_hint": {
          "$ref": "#/$defs/TokenCostHint"
        }
      }
    },
    "AuthConfig": {
      "type": "object",
      "description": "Authentication requirements.",
      "$comment": "Runtime-facing auth and verification hints; no secret material.",
      "additionalProperties": true,
      "properties": {
        "scheme": {
          "description": "Authentication scheme expected by the provider.",
          "examples": ["none", "oauth2"],
          "type": "string",
          "enum": ["none", "api_key", "oauth2", "mtls", "custom"]
        },
        "scopes": {
          "description": "Authorization scopes requested by this object.",
          "examples": [["files.read", "reports.generate"]],
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "issuer": {
          "description": "Token issuer verification hint (common in JWT/OIDC flows).",
          "examples": ["https://auth.example.com"],
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "description": "Token audience verification hint.",
          "examples": ["aop-runtime"],
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "scheme": {
                "const": "oauth2"
              }
            },
            "required": ["scheme"]
          },
          "then": {
            "required": ["scopes", "issuer", "audience"]
          }
        },
        {
          "if": {
            "properties": {
              "scheme": {
                "const": "none"
              }
            },
            "required": ["scheme"]
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": ["scopes"]
                },
                {
                  "required": ["issuer"]
                },
                {
                  "required": ["audience"]
                }
              ]
            }
          }
        }
      ]
    },
    "PermissionConfig": {
      "type": "object",
      "description": "Permission and access boundaries.",
      "$comment": "Used by policy engines for gating decisions and audit trails.",
      "additionalProperties": true,
      "properties": {
        "data_access": {
          "description": "Declared data access level required by the object.",
          "examples": ["read", "read-write"],
          "type": "string",
          "enum": ["none", "read", "write", "read-write"]
        },
        "network_access": {
          "description": "Declared network access requirement.",
          "examples": ["none", "restricted"],
          "type": "string",
          "enum": ["none", "restricted", "unrestricted"]
        },
        "required_resources": {
          "description": "Resource identifiers expected by the object at runtime.",
          "examples": [["filesystem:/workspace", "dataset:analysis/*"]],
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "IntegrityConfig": {
      "type": "object",
      "description": "Integrity and signing metadata.",
      "additionalProperties": true,
      "properties": {
        "checksum_algo": {
          "type": "string",
          "enum": ["sha256", "sha512"]
        },
        "checksum": {
          "type": "string",
          "pattern": "^(?:[A-Fa-f0-9]{64}|[A-Fa-f0-9]{128})$"
        },
        "signed": {
          "type": "boolean"
        },
        "signature_ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["checksum"]
          },
          "then": {
            "required": ["checksum_algo"]
          }
        },
        {
          "if": {
            "properties": {
              "checksum_algo": {
                "const": "sha256"
              }
            },
            "required": ["checksum_algo"]
          },
          "then": {
            "required": ["checksum"],
            "properties": {
              "checksum": {
                "type": "string",
                "pattern": "^[A-Fa-f0-9]{64}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "checksum_algo": {
                "const": "sha512"
              }
            },
            "required": ["checksum_algo"]
          },
          "then": {
            "required": ["checksum"],
            "properties": {
              "checksum": {
                "type": "string",
                "pattern": "^[A-Fa-f0-9]{128}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "signed": {
                "const": true
              }
            },
            "required": ["signed"]
          },
          "then": {
            "required": ["signature_ref"]
          }
        },
        {
          "if": {
            "required": ["signature_ref"]
          },
          "then": {
            "properties": {
              "signed": {
                "const": true
              }
            },
            "required": ["signed"]
          }
        }
      ]
    },
    "Security": {
      "type": "object",
      "description": "Optional security/provenance/integrity declarations.",
      "$comment": "When security is present, auth is required by v0.3 baseline.",
      "additionalProperties": false,
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false,
      "required": ["auth"],
      "properties": {
        "auth": {
          "description": "Authentication contract object (required when security is present).",
          "$ref": "#/$defs/AuthConfig"
        },
        "permissions": {
          "description": "Permission and access hints for policy gating.",
          "$ref": "#/$defs/PermissionConfig"
        },
        "integrity": {
          "description": "Integrity metadata including checksum/signature hints.",
          "$ref": "#/$defs/IntegrityConfig"
        }
      }
    }
  },
  "properties": {
    "aop_version": {
      "type": "string",
      "description": "AOP spec version that this object targets (not the repo tag).",
      "pattern": "^0\\.(?:[1-9]\\d*)$"
    },
    "id": {
      "type": "string",
      "description": "AOP object identifier URN.",
      "pattern": "^urn:aop:(tool|workflow|dataset|policy):[a-z0-9][a-z0-9-]{0,63}:v[0-9]+$"
    },
    "kind": {
      "type": "string",
      "enum": ["tool", "workflow", "dataset", "policy"]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputs", "outputs"],
      "properties": {
        "inputs": {
          "description": "JSON Schema describing invocation inputs.",
          "$ref": "https://json-schema.org/draft/2020-12/schema"
        },
        "outputs": {
          "description": "JSON Schema describing invocation outputs.",
          "$ref": "https://json-schema.org/draft/2020-12/schema"
        }
      }
    },
    "invocation": {
      "$ref": "#/$defs/Invocation"
    },
    "capabilities": {
      "$ref": "#/$defs/Capabilities"
    },
    "security": {
      "$ref": "#/$defs/Security"
    },
    "provenance": {
      "type": "object",
      "description": "Optional publisher/source metadata.",
      "additionalProperties": true
    }
  }
}
