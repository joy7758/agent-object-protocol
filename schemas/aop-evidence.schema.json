{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/joy7758/agent-object-protocol/schemas/aop-evidence.schema.json",
  "title": "AOP Evidence Envelope",
  "type": "object",
  "required": ["aop_version", "id", "kind", "subject", "predicateType", "predicate"],
  "properties": {
    "aop_version": {
      "type": "string",
      "pattern": "^0\\.(?:[1-9]\\d*)$"
    },
    "id": {
      "type": "string",
      "description": "Evidence object URN.",
      "pattern": "^urn:aop:evidence:[a-z0-9][a-z0-9-]{0,63}:v[0-9]+$"
    },
    "kind": {
      "type": "string",
      "const": "evidence"
    },
    "subject": {
      "type": "object",
      "description": "The artifact being attested (id + digest).",
      "required": ["id", "digest"],
      "properties": {
        "id": {
          "type": "string"
        },
        "digest": {
          "$ref": "#/$defs/DigestSet"
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false
    },
    "predicateType": {
      "type": "string",
      "description": "Evidence predicate type URI (e.g., SLSA provenance).",
      "minLength": 8,
      "maxLength": 256
    },
    "predicate": {
      "type": "object",
      "description": "Predicate payload. v0.8 keeps this minimal and schema-valid; richer profiles may be added later."
    },
    "signature": {
      "type": "object",
      "description": "Optional signature reference (verification held for v1).",
      "properties": {
        "signed": {
          "type": "boolean"
        },
        "signature_ref": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "signed": {
                "const": true
              }
            },
            "required": ["signed"]
          },
          "then": {
            "required": ["signature_ref"]
          }
        }
      ],
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false
    },
    "provenance": {
      "type": "object",
      "description": "Optional publisher/provenance metadata."
    }
  },
  "patternProperties": {
    "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
  },
  "unevaluatedProperties": false,
  "$defs": {
    "DigestSet": {
      "type": "object",
      "description": "Digest set for the subject. sha256 is recommended in v0.8 fixtures.",
      "properties": {
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "sha512": {
          "type": "string",
          "pattern": "^[a-f0-9]{128}$"
        }
      },
      "minProperties": 1,
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false
    }
  }
}
