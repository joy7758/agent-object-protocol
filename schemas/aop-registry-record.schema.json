{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/joy7758/agent-object-protocol/schemas/aop-registry-record.schema.json",
  "title": "AOP Registry Record (Non-Normative)",
  "$comment": "Experimental registry shape for v0.4.x discovery workflows.",
  "type": "object",
  "properties": {
    "record_type": {
      "type": "string",
      "const": "aop_registry_record"
    },
    "object_id": {
      "type": "string",
      "pattern": "^urn:aop:(tool|workflow|dataset|policy):[a-z0-9][a-z0-9-]{0,63}:v[0-9]+$"
    },
    "object_version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "kind": {
      "type": "string",
      "enum": ["tool", "workflow", "dataset", "policy"]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "digest": {
      "$ref": "#/$defs/Digest"
    },
    "locations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z][a-zA-Z0-9+.-]*://.+$"
      },
      "uniqueItems": true
    },
    "signature_ref": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T[^\\s]+Z$"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    }
  },
  "required": [
    "record_type",
    "object_id",
    "object_version",
    "digest",
    "locations"
  ],
  "patternProperties": {
    "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
  },
  "unevaluatedProperties": false,
  "$defs": {
    "Digest": {
      "type": "object",
      "properties": {
        "algo": {
          "type": "string",
          "enum": ["sha256", "sha512"]
        },
        "value": {
          "type": "string",
          "pattern": "^(?:[A-Fa-f0-9]{64}|[A-Fa-f0-9]{128})$"
        }
      },
      "required": ["algo", "value"],
      "allOf": [
        {
          "if": {
            "properties": {
              "algo": {
                "const": "sha256"
              }
            },
            "required": ["algo"]
          },
          "then": {
            "properties": {
              "value": {
                "type": "string",
                "pattern": "^[A-Fa-f0-9]{64}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "algo": {
                "const": "sha512"
              }
            },
            "required": ["algo"]
          },
          "then": {
            "properties": {
              "value": {
                "type": "string",
                "pattern": "^[A-Fa-f0-9]{128}$"
              }
            }
          }
        }
      ],
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false
    },
    "Metadata": {
      "type": "object",
      "properties": {
        "publisher": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "patternProperties": {
        "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
      },
      "unevaluatedProperties": false
    }
  }
}
