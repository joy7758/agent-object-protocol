{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/joy7758/agent-object-protocol/schemas/lifecycle/lifecycle-object.schema.json",
  "title": "Lifecycle Object",
  "type": "object",
  "required": [
    "schema_version",
    "object_type",
    "lifecycle_object_id",
    "agent_instance_id",
    "lineage_id",
    "persona_ref",
    "current_state",
    "state_since",
    "governance_profile_ref",
    "receipt_chain_head",
    "evidence_refs",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "object_type": {
      "type": "string",
      "const": "lifecycle_object"
    },
    "lifecycle_object_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 256
    },
    "agent_instance_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128
    },
    "lineage_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128
    },
    "persona_ref": {
      "type": "string",
      "minLength": 3,
      "maxLength": 512
    },
    "current_state": {
      "$ref": "#/$defs/LifecycleState"
    },
    "state_since": {
      "$ref": "#/$defs/Timestamp"
    },
    "governance_profile_ref": {
      "type": "string",
      "minLength": 3,
      "maxLength": 512
    },
    "receipt_chain_head": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 512
      }
    },
    "created_at": {
      "$ref": "#/$defs/Timestamp"
    }
  },
  "patternProperties": {
    "^x-[a-z0-9][a-z0-9-]{0,31}-[a-z0-9][a-z0-9-]{0,63}$": true
  },
  "unevaluatedProperties": false,
  "$defs": {
    "LifecycleState": {
      "type": "string",
      "enum": ["BORN", "ACTIVE", "SUSPENDED", "MERGED", "TERMINATED"]
    },
    "Timestamp": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}T[^\\s]+(?:Z|[+-]\\d{2}:\\d{2})$"
    }
  }
}
