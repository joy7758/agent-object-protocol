{
  "aop_version": "0.5",
  "id": "urn:aop:tool:dangerous-write:v1",
  "kind": "tool",
  "name": "dangerous-write",
  "description": "A tool that may perform high side-effect operations.",
  "schema": {
    "inputs": {
      "type": "object"
    },
    "outputs": {
      "type": "object"
    }
  },
  "invocation": {
    "mode": "sync",
    "idempotency": "non-idempotent"
  },
  "capabilities": {
    "side_effects": "high",
    "determinism": "nondeterministic",
    "token_cost_hint": {
      "input_per_1k": 0,
      "output_per_1k": 0
    }
  },
  "security": {
    "auth": {
      "scheme": "none"
    },
    "permissions": {
      "data_access": "read-write",
      "network_access": "restricted",
      "required_resources": [
        "filesystem:/workspace",
        "secrets:runtime/*"
      ]
    }
  }
}
